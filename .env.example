# ============================================================
# Environment Variables
# Renomeie este arquivo para .env antes de executar o projeto
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/jitterbit_orders

# JWT (opcional - para o recurso de autenticação)
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=24h
